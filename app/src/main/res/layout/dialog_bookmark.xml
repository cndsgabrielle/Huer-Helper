<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/glasscard_bookmark">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#60FFFFFF"
        android:backgroundTint="#60FFFFFF" />

    <!-- Color swatches preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        android:gravity="center">

        <View
            android:id="@+id/dialog_swatch1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="#808080" />

        <!-- Only shown for matched type -->
        <LinearLayout
            android:id="@+id/dialog_swatch2_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" + "
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_gravity="center_vertical" />

            <View
                android:id="@+id/dialog_swatch2"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Label"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_button_bg"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#80FFFFFF"
        android:hint="e.g. My blue shirt"
        android:inputType="text"
        android:singleLine="true"
        android:layout_marginBottom="20dp" />

    <!-- Tags -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Custom Tags"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:chipSpacingHorizontal="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/et_new_tag"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/glass_button_bg"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#80FFFFFF"
            android:hint="Add tag (Work, School, Home...)"
            android:inputType="text"
            android:singleLine="true"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_tag"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#4A90E2"
            app:cornerRadius="14dp"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Save / Cancel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_save"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_gradient_purple"
            app:backgroundTint="@null"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/glass_button_bg"
            app:backgroundTint="@null"
            app:cornerRadius="18dp" />
    </LinearLayout>

</LinearLayout>